############################
# Trading Credentials
############################
# 建议复制本文件为 ../.env.demo 与 ../.env.live，然后填入不同账号。
# Demo / Practice (OANDA)
OANDA_ACCOUNT_ID_DEMO=101-000-00000000-001
OANDA_TOKEN_DEMO=practice-token
OANDA_URL_DEMO=https://api-fxpractice.oanda.com/v3

# Live / Production (OANDA)
OANDA_ACCOUNT_ID_LIVE=101-000-00000000-002
OANDA_TOKEN_LIVE=live-token
OANDA_URL_LIVE=https://api-fxtrade.oanda.com/v3

# QuantTrader / QuantResearch 脚本运行前，选择性导出：
#   source ../.env.demo && export OANDA_ACCOUNT_ID=$OANDA_ACCOUNT_ID_DEMO ...
# 或者使用 helper 脚本（参见 docs/parallel_fence.md）。
