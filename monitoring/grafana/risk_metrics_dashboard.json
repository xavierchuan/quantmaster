{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.5.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Rejects",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_rejects{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "alert": {
        "alertRuleTags": { "metric": "rejects" },
        "conditions": [
          {
            "evaluator": { "params": [0], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "name": "Rejects > 0",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 2,
      "title": "Latency Avg (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_latency_ms_avg{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "alert": {
        "alertRuleTags": { "metric": "latency_avg" },
        "conditions": [
          {
            "evaluator": { "params": [500], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "name": "Avg latency high",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 3,
      "title": "Latency P95 (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_latency_ms_p95{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 400 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "alert": {
        "alertRuleTags": { "metric": "latency_p95" },
        "conditions": [
          {
            "evaluator": { "params": [600], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "name": "Latency P95 high",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 4,
      "title": "Total Net PnL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_total_pnl{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Live Sharpe (30d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_live_sharpe_30d{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1.0 },
              { "color": "green", "value": 1.4 }
            ]
          }
        }
      },
      "alert": {
        "alertRuleTags": { "metric": "live_sharpe" },
        "conditions": [
          {
            "evaluator": { "params": [1.4], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "6h", "now"] },
            "reducer": { "type": "min" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "5m",
        "handler": 1,
        "name": "Sharpe below target",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 6,
      "title": "Live Drawdown",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_live_drawdown_pct{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "alert": {
        "alertRuleTags": { "metric": "live_drawdown" },
        "conditions": [
          {
            "evaluator": { "params": [0.05], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "6h", "now"] },
            "reducer": { "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "5m",
        "handler": 1,
        "name": "Live drawdown high",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 7,
      "title": "Slippage (bps)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_slippage_bps{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "alert": {
        "alertRuleTags": { "metric": "slippage" },
        "conditions": [
          {
            "evaluator": { "params": [2.0], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "1h", "now"] },
            "reducer": { "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "5m",
        "handler": 1,
        "name": "Slippage high",
        "noDataState": "keep_state",
        "notifications": []
      }
    },
    {
      "id": 8,
      "title": "Max Exposure",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_max_symbol_exposure{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2000000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "alert": {
        "alertRuleTags": { "metric": "exposure" },
        "conditions": [
          {
            "evaluator": { "params": [2000000], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "max" },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "name": "Exposure breach",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 9,
      "title": "Max Drawdown (Backtest)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "risk_max_drawdown_pct{job=\"risk_sim\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.08 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Live vs Paper PnL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "risk_total_pnl{job=\"risk_sim\"}", "legendFormat": "Live", "refId": "A" },
        { "expr": "paper_total_pnl{job=\"risk_sim\"}", "legendFormat": "Paper", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 11,
      "title": "Latencies over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "risk_latency_ms_avg{job=\"risk_sim\"}", "legendFormat": "Avg", "refId": "A" },
        { "expr": "risk_latency_ms_p95{job=\"risk_sim\"}", "legendFormat": "P95", "refId": "B" },
        { "expr": "risk_live_latency_ms_p95{job=\"risk_sim\"}", "legendFormat": "Live P95", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["risk", "fx", "live"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "RiskSim – FX Metrics (Alerts)",
  "uid": "risk-sim-fx",
  "version": 1,
  "weekStart": ""
}
